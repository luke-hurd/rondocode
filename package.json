{
  "name": "rondocode",
  "private": true,
  "description": "Live-codeable synths and mini-notation patterns in the browser, with a from-scratch AudioWorklet DSP engine.",
  "license": "MIT",
  "author": "Vijay Pemmaraju",
  "homepage": "https://rondocode.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/vijaypemmaraju/rondocode"
  },
  "keywords": [
    "live-coding",
    "synthesizer",
    "audio",
    "webaudio",
    "audioworklet",
    "music",
    "mini-notation",
    "dsp"
  ],
  "scripts": {
    "dev": "pnpm --filter @rondocode/app dev",
    "jam": "partykit dev --port 1999",
    "jam:deploy": "partykit deploy",
    "bridge": "pnpm --filter @rondocode/server exec tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "node ./node_modules/@biomejs/biome/bin/biome lint packages --error-on-warnings=false"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "partykit": "^0.0.115",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "y-partykit": "^0.0.33",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  }
}
